{
  "name": "local-life-hotspot",
  "displayName": "干货内容助手",
  "version": "3.0.0",
  "description": "专业的干货内容搜索和创作工具。搜索具体的技巧、方法、经验（非热点摘要），创作有价值的小红书干货文章。支持职场、学习、科技、生活等领域，自动生成详细干货清单和实用建议。",
  "author": "githubsoftware2015",
  "license": "MIT",
  "keywords": [
    "干货内容",
    "技巧方法",
    "小红书",
    "内容创作",
    "职场技巧",
    "学习方法",
    "经验分享"
  ],
  "category": "内容创作",
  "main": "run.py",
  "scripts": {
    "start": "python3 run.py"
  },
  "dependencies": {
    "python": ">=3.8",
    "Pillow": ">=9.0.0"
  },
  "engines": {
    "openclaw": ">=0.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/githubsoftware2015/local-life-hotspot"
  },
  "bugs": {
    "url": "https://github.com/githubsoftware2015/local-life-hotspot/issues"
  },
  "homepage": "https://clawhub.ai/skills/local-life-hotspot",
  "usage": {
    "triggers": [
      "干货内容",
      "职场技巧",
      "学习方法",
      "实用干货",
      "创作小红书"
    ],
    "examples": [
      "搜索职场技巧，创作干货文章",
      "帮我找学习方法，Top 10",
      "科技知识干货，自动发布",
      "生活小妙招，15 条"
    ],
    "parameters": {
      "keyword": "搜索关键词（如：职场技巧、学习方法、科技知识）",
      "topN": "干货技巧数量（如：5、10、15）",
      "autoPublish": "是否自动发布到小红书"
    }
  },
  "config": {
    "requiredMCP": [
      "xiaohongshu"
    ],
    "optionalMCP": []
  },
  "changelog": {
    "3.0.0": [
      "核心升级：搜索具体干货内容，非热点摘要",
      "支持从网页提取实用技巧和方法",
      "生成详细的干货清单（5-15 条技巧）",
      "内置示例干货库（职场/学习/科技）"
    ],
    "2.0.0": [
      "移除微信确认步骤",
      "关键词和热点数量可配置"
    ],
    "1.0.0": [
      "初始版本"
    ]
  }
}
