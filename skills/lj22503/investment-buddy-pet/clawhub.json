{
  "name": "investment-buddy-pet",
  "version": "1.1.0",
  "description": "投资宠物技能 - 12 只宠物陪伴你投资成长，提供情感陪伴、定投提醒、投资者教育（v1.1.0 新增自我进化能力）",
  "author": "燃冰 + ant",
  "license": "MIT",
  "keywords": [
    "投资",
    "宠物",
    "陪伴",
    "定投",
    "提醒",
    "投资者教育",
    "金融合规"
  ],
  "category": "finance",
  "tags": [
    "investment",
    "pet",
    "companion",
    "education",
    "compliance"
  ],
  "main": "SKILL.md",
  "files": [
    "SKILL.md",
    "README.md",
    "clawhub.json",
    "pets/*.json",
    "scripts/*.py",
    "docs/*.md",
    "docs/knowledge/*.md",
    "examples/*.md",
    "references/*.md"
  ],
  "scripts": {
    "test": "python3 scripts/compliance_checker.py",
    "start": "python3 scripts/heartbeat_engine.py start --user-id <your_user_id> --pet-type <pet_id>"
  },
  "dependencies": {
    "python": ">=3.6",
    "requests": ">=2.31.0",
    "sqlite3": "builtin"
  },
  "compliance": {
    "level": "financial_services",
    "features": [
      "不推荐具体产品",
      "不承诺收益",
      "不提供择时建议",
      "用户数据本地存储",
      "合规检查器集成"
    ],
    "disclaimer": "本技能为投资者教育工具，不构成投资建议。市场有风险，投资需谨慎。"
  },
